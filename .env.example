# trading-tom — environment configuration
# Copy to .env and fill in secrets

# App
APP_ENV=development
DEBUG=true

# Database
POSTGRES_DB=trading_tom
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
DATABASE_URL=postgresql://dev:dev@db:5432/trading_tom

# Market data provider (yfinance needs no key; alpaca free tier optional)
# ALPACA_API_KEY=
# ALPACA_API_SECRET=

# Trading simulation
STARTING_CAPITAL=10000
ACCOUNT_FLOOR=0

# Claude API (deferred — set if architecture decides to use it)
# ANTHROPIC_API_KEY=
