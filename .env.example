# trading-tom — environment configuration
# Copy to .env and fill in secrets

# App
APP_ENV=development
DEBUG=true

# Database
POSTGRES_DB=trading_tom
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
DATABASE_URL=postgresql://dev:dev@db:5432/trading_tom

# Operator auth (protect control endpoints)
OPERATOR_TOKEN=changeme

# Market data provider (yfinance needs no key; alpaca free tier optional)
DATA_PROVIDER=yfinance
# ALPACA_API_KEY=
# ALPACA_API_SECRET=

# Trading simulation
STARTING_CAPITAL_CENTS=1000000
ACCOUNT_FLOOR_CENTS=0

# Fee model (published US regulatory rates; update as needed)
COMMISSION_CENTS=0
SEC_FEE_RATE=0.0000229
FINRA_TAF_PER_SHARE=0.000145
FINRA_TAF_CAP_CENTS=727

# Data split ratios (must sum to 1.0; test is implied remainder)
SPLIT_TRAIN_RATIO=0.60
SPLIT_VALIDATION_RATIO=0.20

# Default watchlist (comma-separated tickers)
WATCHLIST=AAPL,MSFT,NVDA,TSLA,AMZN,GOOGL,META,SPY

# Claude API integration (optional — off by default)
ENABLE_CLAUDE_SUMMARY=false
# ANTHROPIC_API_KEY=
